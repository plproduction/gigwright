# Copy this file to `.env` and fill in the real values.
# Never commit `.env` — it's already in .gitignore.

# --- Postgres (Neon) ---
# From Neon dashboard → your project → Connection string → "Prisma" format
# Example: postgresql://user:pw@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=""

# --- Auth.js ---
# Used to sign/encrypt session cookies and magic-link tokens.
# Generate with:  openssl rand -base64 32
AUTH_SECRET=""

# Full origin of the app. Locally this is http://localhost:3000.
# In production (Vercel), set this to https://your-domain.com
AUTH_URL="http://localhost:3000"

# --- Resend (magic-link email delivery) ---
# From Resend dashboard → API Keys
AUTH_RESEND_KEY=""

# Sender address. Until you verify a domain in Resend, use the shared
# testing address `onboarding@resend.dev` — it only sends to the email
# you signed up with.
EMAIL_FROM="onboarding@resend.dev"

# --- Twilio (SMS alerts — wired up in a follow-up pass) ---
# From Twilio Console → Account → API keys & tokens
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Your purchased Twilio number in E.164 format, e.g. +15615551234
TWILIO_FROM_NUMBER=""
