// Gigwright database schema.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════
// Auth.js models (magic-link email flow)
// ═══════════════════════════════════════════════════════════════

enum UserRole {
  ADMIN     // Patrick — sees all tenants, manages subscriptions, overrides limits
  OWNER     // Paying bandleader — runs the app for their gigs
  MUSICIAN  // Sideman — sees only gigs they're assigned to, read-only, no finances
}

enum Plan {
  FREE
  PRO
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  role UserRole @default(OWNER)
  plan Plan     @default(FREE)

  // Stripe wiring (populated once subscriptions are live)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  currentPeriodEnd     DateTime?

  accounts  Account[]
  sessions  Session[]
  venues    Venue[]
  musicians Musician[]                          // as owner (bandleader's roster)
  playsAs   Musician[]  @relation("MusicianUser") // as musician (where they play)
  gigs      Gig[]
  qbo       QboConnection?
}

// QuickBooks Online OAuth tokens + company pointer. Access tokens expire in
// ~1 hour; refresh tokens in 100 days (Intuit auto-rotates refresh tokens on
// each use — we persist the new one each time we refresh).
model QboConnection {
  id      String @id @default(cuid())
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  realmId      String  // QBO company ID
  accessToken  String  @db.Text
  refreshToken String  @db.Text
  expiresAt    DateTime

  // Which QBO account do band-pay bills post into? Defaults to the first
  // account whose name contains "Contract" on connect; user can override in
  // the Settings → Integrations page.
  defaultExpenseAccountId   String?
  defaultExpenseAccountName String?

  connectedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ═══════════════════════════════════════════════════════════════
// Gigwright domain
// ═══════════════════════════════════════════════════════════════

enum CalendarProvider {
  ICLOUD
  GOOGLE
  OUTLOOK
  NONE
}

enum PaymentMethod {
  VENMO
  PAYPAL
  ZELLE
  CASHAPP
  CASH
  CHECK
  DIRECT_DEPOSIT
  OTHER
}

enum GigStatus {
  INQUIRY
  HOLD
  CONFIRMED
  PLAYED
  CANCELLED
}

model Venue {
  id         String  @id @default(cuid())
  name       String
  addressL1  String?
  addressL2  String?
  city       String?
  state      String?
  postalCode String?
  country    String  @default("US")
  phone      String?
  contactName  String?
  contactEmail String?
  notes      String?
  timezone   String  @default("America/New_York")

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  gigs Gig[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Musician {
  id        String  @id @default(cuid())
  name      String
  email     String?
  phone     String?
  initials  String? // e.g. "DR" — overrideable, otherwise derived from name
  avatarUrl String? // Vercel Blob URL — headshot shown on roster and gig personnel rows

  // Linked User (nullable) — populated once the musician logs in via a matching
  // email. One User can be linked to multiple Musician rows across tenants.
  userId     String?
  user       User?   @relation("MusicianUser", fields: [userId], references: [id])
  invitedAt  DateTime? // when the admin sent them the login invite email

  // Roles, freeform — e.g. ["Drums"], ["Sax", "Arranger"]
  roles String[]

  isLeader Boolean @default(false)

  calendarProvider CalendarProvider @default(NONE)
  paymentMethod    PaymentMethod?

  // The destination to send money: Zelle email/phone, Venmo @handle,
  // PayPal email, Cashtag (with or without $), etc. Interpreted based on
  // paymentMethod.
  payoutAddress    String?

  notifyBySms   Boolean @default(true)
  notifyByEmail Boolean @default(true)

  // W-9 tracking — every outbound message auto-includes either a request
  // (if not received) or a "W-9 received" confirmation (if received).
  w9Received   Boolean   @default(false)
  w9ReceivedAt DateTime?

  notes String?

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  gigPersonnel GigPersonnel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Gig {
  id String @id @default(cuid())

  // Core date/time fields
  // startAt is the authoritative "when is this gig" field (downbeat time).
  // The detail screen also tracks optional load-in, soundcheck, and end times.
  startAt      DateTime // Downbeat
  loadInAt     DateTime?
  soundcheckAt DateTime?
  callTimeAt   DateTime?
  endAt        DateTime? // null = "open"

  status GigStatus @default(CONFIRMED)

  // Money — all values stored in cents.
  clientPayCents     Int? // What the client pays leader
  clientDepositCents Int? // Deposit collected so far

  // Tech & logistics (mirrors the mockup)
  sound             String? // e.g. "House FOH"
  soundContactName  String? // e.g. "Joe the house engineer"
  soundContactPhone String? // e.g. "(561) 555-1234"
  lights            String? // e.g. "House"
  attire            String? // e.g. "Black on black"
  meal              String? // e.g. "After check · green room"

  // Clickable link to the folder/drive with all charts, arrangements, audio
  materialsUrl String?

  // Uploaded set list (Vercel Blob URL) + original filename + when last changed,
  // so we can fire an SMS/email fanout on swap.
  setlistUrl       String?
  setlistFileName  String?
  setlistUpdatedAt DateTime?

  notes String?

  // QuickBooks sync state. qboSyncedAt is set every time we push this gig's
  // bills to QBO; if updatedAt > qboSyncedAt, the UI shows "Changes unsynced
  // — Re-push" state. qboSyncError caches the last push error for display.
  qboSyncedAt DateTime?
  qboSyncError String?

  venueId String?
  venue   Venue?  @relation(fields: [venueId], references: [id])

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  personnel GigPersonnel[]
  expenses  GigExpense[]
  activity  Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, startAt])
}

// Freeform line items for a gig — flights, hotels, ad spend, transportation,
// food, anything that isn't musician pay. Modeled after the Iridium Payout
// worksheet pattern: add rows as needed, everything rolls up into the net.
model GigExpense {
  id     String @id @default(cuid())
  gigId  String
  gig    Gig    @relation(fields: [gigId], references: [id], onDelete: Cascade)

  label       String
  amountCents Int
  category    String? // optional grouping (travel, promo, meals, etc.)
  position    Int @default(0)

  paidAt DateTime? // when the expense was paid / cleared

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gigId])
}

model GigPersonnel {
  id String @id @default(cuid())

  gigId      String
  gig        Gig      @relation(fields: [gigId], references: [id], onDelete: Cascade)
  musicianId String
  musician   Musician @relation(fields: [musicianId], references: [id], onDelete: Cascade)

  roleLabel String? // Override of musician.roles for this specific gig, optional
  payCents  Int     @default(0)
  position  Int     @default(0)

  paidAt         DateTime?
  paidMethod     PaymentMethod?

  calendarSynced Boolean   @default(false)
  calendarSyncedAt DateTime?

  // Per-row QBO pointers so we can update/void the exact bill if the pay
  // amount changes post-push.
  qboVendorId String?
  qboBillId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gigId, musicianId])
  @@index([gigId])
  @@index([musicianId])
}

// Timeline of changes on a gig — the foundation for "diff-aware notifications"
// and the activity feed shown in the mockup's gig detail page.
model Activity {
  id String @id @default(cuid())

  gigId String
  gig   Gig    @relation(fields: [gigId], references: [id], onDelete: Cascade)

  // Structured action + human-readable summary
  action  String // e.g. "gig_alert_sent", "time_updated", "personnel_added"
  summary String // e.g. "Gig alert sent to 3", "Time updated · diff text sent"

  // Optional machine-readable diff payload
  payload Json?

  createdAt DateTime @default(now())

  @@index([gigId, createdAt])
}
